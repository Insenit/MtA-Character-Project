import calculateFinalAC from '../ac/calculateFinalAC';
import { calculateSavingThrows } from '../saves/SavingThrowCalculator';
import { calculateSpellSlots } from '../spellcasting/SlotHandler';
import { calculateExploitDice } from '../exploits/ExploitDiceHandler';

export function prepareCharacter(base) {
  const enriched = {
    ...base,
    ac: { value: calculateFinalAC(base) },
    saves: calculateSavingThrows(base),
    spellSlots: calculateSpellSlots(base.classes),
    exploits: {
      ...base.exploits,
      ...calculateExploitDice(base)
    },
    currency: base.currency ?? { cp: 0, sp: 0, ep: 0, gp: 0, pp: 0 },
    proficiencies: base.proficiencies ?? {
      armor: [],
      weapons: [],
      tools: [],
      skills: [],
      savingThrows: []
    }
  };

  return reorderCharacter(enriched);
}

export function reorderCharacter(character) {
  return {
    id: character.id,
    name: character.name,
    race: character.race,
    background: character.background,
    totalLevel: character.totalLevel,
    hpState: character.hpState,
    ac: character.ac,
    saves: character.saves,
    stats: character.stats,
    proficiencies: character.proficiencies,
    features: character.features,
    inventory: character.inventory,
    spells: character.spells,
    spellSlots: character.spellSlots,
    exploits: character.exploits,
    classes: character.classes,
  };
}